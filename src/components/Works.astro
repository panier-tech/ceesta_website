---
const projects = [
{ title: "Idea & Concept", desc: "心に浮かんだ色彩や形、言葉の記録", tag: "Creative" },
{ title: "Selected Works", desc: "光を紡ぐ", tag: "Portfolio" },
{ title: "JourneyLog", desc: "cesta(道・旅)の途中で出会った景色や記憶", tag: "Blog" }
];
---
<section id="works" class="works">
    <div class="container">
        <h2>Works & Contents</h2>
        <div class="grid">
            {projects.map((project) => (
            <div class="card">
                <span class="tag">{project.tag}</span>
                <h3>{project.title}</h3>
                <p>{project.desc}</p>
            </div>
            ))}
        </div>
    </div>
</section>
<style>
    .works {
        padding: 100px 20px;
        background: #12141c;
    }

    .container {
        max-width: 1000px;
        margin: 0 auto;

    }

    h2 {
        text-align: center;
        font-size: 2rem;
        color: #fff;
        margin-bottom: 60px;
        font-weight: 300;
    }

    .grid {
        display: block;
    }

    .card {
        background: #1f2833;
        border: 1px solid transparent;
        border-radius: 12px;
        padding: 30px;
        margin-bottom: 20px;
        transition: all 0.4s ease;
        cursor: pointer;
        position: relative;
    }

    .card:hover {
        border-color: var(--accent-gold);
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(229, 193, 88, 0.1);
    }

    .tag {
        font-size: 0.8rem;
        color: var(--accent-cyan);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    h3 {
        font-size: 1.4rem;
        color: #fff;
        margin: 10px 0;
        font-weight: 400;
    }

    p {
        color: #max-width;
        margin: 0;
        font-size: 1rem;
    }

    /* スマホ画面（幅768px以下）での見え方を調整 */
    @media (max-width: 768px) {
        .grid {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }
    }
</style>